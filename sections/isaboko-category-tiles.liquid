{%- comment -%}
  Isaboko category tiles — 2x2 grid of image tiles with overlaid labels.
  Visual styles live in assets/isaboko.css under "CATEGORY TILES".
{%- endcomment -%}

{%- assign used_tile_images = '' -%}
<div class="isaboko-categories">
  <div class="isaboko-categories__grid">
    {%- for block in section.blocks -%}
      <a
        class="isaboko-categories__tile"
        href="{{ block.settings.link }}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 1200
            | image_tag:
                class: 'isaboko-categories__img',
                loading: 'lazy',
                widths: '600, 800, 1000, 1200',
                sizes: '(min-width: 750px) 50vw, 100vw'
          }}
          {%- assign used_tile_images = used_tile_images | append: '|' | append: block.settings.image.src -%}
        {%- else -%}
          {%- comment -%} Pull fallback image from the collection, skipping any already used {%- endcomment -%}
          {%- assign tile_handles = "new,bags,jackets-and-coats,accessories" | split: "," -%}
          {%- assign tile_handle = tile_handles[forloop.index0] -%}
          {%- assign tile_fallback = blank -%}
          {%- for product in collections[tile_handle].products -%}
            {%- if tile_fallback != blank -%}{%- continue -%}{%- endif -%}
            {%- assign candidate = product.featured_image -%}
            {%- if candidate == blank -%}{%- continue -%}{%- endif -%}
            {%- assign candidate_src = candidate | image_url: width: 1200 -%}
            {%- if used_tile_images contains candidate_src -%}{%- continue -%}{%- endif -%}
            {%- assign tile_fallback = candidate -%}
            {%- assign used_tile_images = used_tile_images | append: '|' | append: candidate_src -%}
          {%- endfor -%}
          {%- if tile_fallback != blank -%}
            {{ tile_fallback | image_url: width: 1200 | image_tag:
              class: 'isaboko-categories__img',
              loading: 'lazy',
              widths: '600, 800, 1000, 1200',
              sizes: '(min-width: 750px) 50vw, 100vw'
            }}
          {%- else -%}
            <div class="isaboko-categories__placeholder">
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        {%- endif -%}
        <span class="isaboko-categories__label">{{ block.settings.label }}</span>
      </a>
    {%- endfor -%}
  </div>
  <div class="isaboko-categories__border"></div>
</div>

{% schema %}
{
  "name": "Category tiles (Isaboko)",
  "tag": "section",
  "class": "isaboko-categories-section",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category tiles (Isaboko)",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "label": "NEW",
            "link": "/collections/new"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "BAGS",
            "link": "/collections/bags"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "JACKETS",
            "link": "/collections/jackets-and-coats"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "ACCESSORIES",
            "link": "/collections/accessories"
          }
        }
      ]
    }
  ]
}
{% endschema %}
