{%- comment -%}
  Isaboko lookbook — editorial/lifestyle image grid on a black background.
  Lime text overlays on images, lime heading, lime newsletter bar at bottom.
  CSS lives in assets/isaboko.css under "LOOKBOOK".
{%- endcomment -%}

{%- assign photos = section.blocks | where: 'type', 'photo' -%}

<section class="isaboko-lookbook" data-section-id="{{ section.id }}">
  <div class="isaboko-lookbook__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="isaboko-lookbook__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.view_all_link != blank -%}
      <a href="{{ section.settings.view_all_link }}" class="isaboko-lookbook__view-all">VIEW ALL</a>
    {%- endif -%}
  </div>

  <div class="isaboko-lookbook__grid">
    {%- for block in photos -%}
      <div
        class="isaboko-lookbook__item{% if block.settings.column_span == '2' %} isaboko-lookbook__item--wide{% endif %}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="isaboko-lookbook__link">
        {%- endif -%}

        <div class="isaboko-lookbook__image-wrapper">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag:
              class: 'isaboko-lookbook__image',
              loading: 'lazy',
              widths: '400, 600, 800, 1200',
              sizes: '(min-width: 990px) 50vw, 100vw'
            }}
          {%- else -%}
            {%- comment -%} Pull editorial images from specific products matching each lookbook entry {%- endcomment -%}
            {%- assign lb_handles = "button-bolo-in-brass,theo-coat,patchwork-scarf,one-of-one-zatsuyo-jacket-l-xl" | split: "," -%}
            {%- assign lb_handle = lb_handles[forloop.index0] -%}
            {%- assign lb_fallback = all_products[lb_handle].featured_image -%}
            {%- if lb_fallback != blank -%}
              {{ lb_fallback | image_url: width: 1200 | image_tag:
                class: 'isaboko-lookbook__image',
                loading: 'lazy',
                widths: '400, 600, 800, 1200',
                sizes: '(min-width: 990px) 50vw, 100vw'
              }}
            {%- else -%}
              {%- assign placeholder_index = forloop.index | modulo: 2 | plus: 1 -%}
              {{ 'lifestyle-' | append: placeholder_index | placeholder_svg_tag: 'isaboko-lookbook__placeholder' }}
            {%- endif -%}
          {%- endif -%}

          {%- if block.settings.label != blank -%}
            <span class="isaboko-lookbook__label">{{ block.settings.label | escape }}</span>
          {%- endif -%}
        </div>

        {%- if block.settings.link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endfor -%}

    {%- if photos.size == 0 -%}
      {%- for i in (1..9) -%}
        <div class="isaboko-lookbook__item{% if i == 4 %} isaboko-lookbook__item--wide{% endif %}">
          <div class="isaboko-lookbook__image-wrapper">
            {%- assign placeholder_index = i | modulo: 2 | plus: 1 -%}
            {{ 'lifestyle-' | append: placeholder_index | placeholder_svg_tag: 'isaboko-lookbook__placeholder' }}
            <span class="isaboko-lookbook__label">PLACEHOLDER {{ i }}</span>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if section.settings.newsletter_text != blank -%}
    <div class="isaboko-lookbook__newsletter">
      {%- if section.settings.newsletter_link != blank -%}
        <a href="{{ section.settings.newsletter_link }}" class="isaboko-lookbook__newsletter-link">
          {{ section.settings.newsletter_text | escape }}
        </a>
      {%- else -%}
        <span class="isaboko-lookbook__newsletter-text">
          {{ section.settings.newsletter_text | escape }}
        </span>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Lookbook (Isaboko)",
  "tag": "section",
  "class": "isaboko-lookbook-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PIECES FROM OUR PAST THAT WE'RE HAUNTED BY"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All link"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter bar text",
      "default": "SIGN UP FOR ISABOKO NEWSLETTER"
    },
    {
      "type": "url",
      "id": "newsletter_link",
      "label": "Newsletter bar link"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label overlay",
          "info": "Lime text shown at the bottom-left of the image."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "column_span",
          "label": "Column span",
          "options": [
            { "value": "1", "label": "1 column" },
            { "value": "2", "label": "2 columns (wide)" }
          ],
          "default": "1",
          "info": "Set to 2 columns for a wide image that spans two grid cells."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook (Isaboko)",
      "blocks": [
        { "type": "photo", "settings": { "label": "CAMP ISABOKO", "column_span": "1" } },
        { "type": "photo", "settings": { "label": "PROSPECT PARK", "column_span": "1" } },
        { "type": "photo", "settings": { "label": "EVERYTHING BAD I'VE EVER DONE", "column_span": "1" } },
        { "type": "photo", "settings": { "label": "SOLAR PUNK CITY", "column_span": "1" } }
      ]
    }
  ]
}
{% endschema %}
