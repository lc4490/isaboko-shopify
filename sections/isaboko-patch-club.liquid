{%- comment -%}
  Isaboko Patch Club — split 50/50 promo for homepage.
  Left: heading, subheading, body text, CTA button.
  Right: two stacked images from section settings.
  CSS lives in assets/isaboko.css under "PATCH CLUB".
{%- endcomment -%}

<section class="isaboko-patch-club" data-section-id="{{ section.id }}">
  <div class="isaboko-patch-club__inner">
    {%- comment -%} LEFT — text content {%- endcomment -%}
    <div class="isaboko-patch-club__text">
      {%- if section.settings.heading != blank -%}
        <h2 class="isaboko-patch-club__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="isaboko-patch-club__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="isaboko-patch-club__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}

      <a
        href="{{ section.settings.cta_link | default: '/products/patch-club' }}"
        class="isaboko-button isaboko-button--black"
      >
        {{ section.settings.cta_text | default: 'SHOP READY TO SHIP' | escape }}&nbsp;&rarr;
      </a>
    </div>

    {%- comment -%} RIGHT — single image {%- endcomment -%}
    <div class="isaboko-patch-club__images">
      <div class="isaboko-patch-club__image-wrap">
        {%- if section.settings.image_1 != blank -%}
          {{ section.settings.image_1 | image_url: width: 1200 | image_tag:
            class: 'isaboko-patch-club__img',
            loading: 'lazy',
            widths: '400, 600, 800, 1200',
            sizes: '(min-width: 990px) 50vw, 100vw'
          }}
        {%- else -%}
          {%- assign pc_fallback_1 = all_products['patch-club'].featured_image -%}
          {%- if pc_fallback_1 != blank -%}
            {{ pc_fallback_1 | image_url: width: 1200 | image_tag:
              class: 'isaboko-patch-club__img',
              loading: 'lazy',
              widths: '400, 600, 800, 1200',
              sizes: '(min-width: 990px) 50vw, 100vw'
            }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'isaboko-patch-club__placeholder' }}
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Patch Club (Isaboko)",
  "tag": "section",
  "class": "isaboko-patch-club-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PATCH CLUB"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "5 patches, mailed to you once a month"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Handmade from vintage kimonos, straight from our studio. A piece of inspiration for you to mend your garments with."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "SHOP READY TO SHIP"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Patch Club (Isaboko)"
    }
  ]
}
{% endschema %}
