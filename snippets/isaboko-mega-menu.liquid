  </ul>
</nav>

{%- comment -%}
  Two scripts:
    1. Hover-to-open: <details> doesn't render non-summary children when closed,
       so CSS :hover alone can't reveal the panel. We toggle details.open on
       mouseenter / mouseleave, which fires Dawn's [open]-based fade. The 150ms
       leave-delay covers brief cursor traversal from summary to panel.
    2. Summary-link click: clicking the <a> inside a <summary> would normally
       both navigate AND toggle the <details>. We preventDefault + stopPropagation
       and manually navigate so click goes ONLY to the destination URL.
{%- endcomment -%}
<script>
  (function () {
    document.querySelectorAll('.isaboko-mega-menu:not([data-hover-init])').forEach(function (details) {
      details.dataset.hoverInit = 'true';
      var leaveTimer;

      details.addEventListener('mouseenter', function () {
        clearTimeout(leaveTimer);
        if (!details.open) details.open = true;
      });

      details.addEventListener('mouseleave', function () {
        leaveTimer = setTimeout(function () {
          details.open = false;
        }, 150);
      });

      var summaryLink = details.querySelector('summary > a');
      if (summaryLink) {
        summaryLink.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          window.location.href = summaryLink.href;
        });
      }
    });
  })();
</script>
